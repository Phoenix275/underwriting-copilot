# The committed artifact is always a read-only snapshot.
#
# `npm run release` builds with --mode snapshot so a developer's .env.local
# (which points at a local API) can never be baked into the file that ships to
# Streamlit and GitHub Pages. A live deployment uses `npm run build` instead,
# with VITE_API_URL supplied by the host.
VITE_API_URL=
